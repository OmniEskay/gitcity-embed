{
  "name": "gitcity-embed",
  "version": "0.1.0",
  "description": "Standalone SVG city visualization service for GitHub profiles",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "node dist/serve.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "better-sqlite3": "^11",
    "hono": "^4",
    "lru-cache": "^10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^2",
    "eslint": "^9",
    "prettier": "^3",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
